      - cookieAuth: []
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/VariantSuggestion'
          description: ''
    put:
      operationId: variant_suggestions_update
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this variant suggestion.
        required: true
      tags:
      - variant-suggestions
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/VariantSuggestionRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/VariantSuggestionRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/VariantSuggestionRequest'
        required: true
      security:
      - basicAuth: []
      - cookieAuth: []
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/VariantSuggestion'
          description: ''
    patch:
      operationId: variant_suggestions_partial_update
      parameters:
      - in: path
        name: id
        schema:
