          type: boolean
        oathbreaker:
          type: boolean
        predh:
          type: boolean
        brawl:
          type: boolean
        vintage:
          type: boolean
        legacy:
          type: boolean
        premodern:
          type: boolean
        modern:
          type: boolean
        pioneer:
          type: boolean
        standard:
          type: boolean
        pauper:
          type: boolean
