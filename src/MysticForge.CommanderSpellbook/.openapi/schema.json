      - cookieAuth: []
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/PaginatedVariantAliasList'
          description: ''
  /variant-aliases/{id}/:
    get:
      operationId: variant_aliases_retrieve
      parameters:
      - in: path
        name: id
        schema:
          type: string
          description: Unique id of this variant alias
        required: true
      tags:
      - variant-aliases
      security:
      - basicAuth: []
      - cookieAuth: []
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/VariantAlias'
          description: ''
  /variant-suggestions/:
    get:
      operationId: variant_suggestions_list
      parameters:
      - name: count
        required: false
