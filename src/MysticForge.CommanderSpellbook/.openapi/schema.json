        imageUriBackLarge:
          type: string
          format: uri
          nullable: true
          title: Image URI of the back of the card in large format
          maxLength: 200
        imageUriBackNormal:
          type: string
          format: uri
          nullable: true
          title: Image URI of the back of the card in normal format
          maxLength: 200
        imageUriBackSmall:
          type: string
          format: uri
          nullable: true
          title: Image URI of the back of the card in small format
          maxLength: 200
        imageUriBackArtCrop:
          type: string
          format: uri
          nullable: true
          title: Image URI of the back of the card art crop
          maxLength: 200
        features:
          type: array
          items:
            $ref: '#/components/schemas/FeatureOfCard'
          readOnly: true
        legalities:
          allOf:
          - $ref: '#/components/schemas/CardLegalities'
