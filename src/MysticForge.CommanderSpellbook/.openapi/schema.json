          pattern: ^(?:(?:\{(?:C\/[WUBRG]|[WUBRG](?:\/P)?|[0-9CPXYZS\u221e]|[1-9][0-9]{1,2}|(?:2\/[WUBRG]|W\/U|W\/B|U\/B|U\/R|B\/R|B\/G|R\/G|R\/W|G\/W|G\/U)(?:\/P)?)\})[^\{\}]*)*$
