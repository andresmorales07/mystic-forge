components:
  schemas:
    BracketTagEnum:
      enum:
      - R
      - S
      - P
      - O
      - C
      - E
      - B
      type: string
      description: |-
        * `R` - Ruthless
        * `S` - Spicy
        * `P` - Powerful
        * `O` - Oddball
        * `C` - Core
        * `E` - Exhibition
        * `B` - Banned
    Card:
      type: object
      properties:
        id:
          type: integer
          readOnly: true
        name:
          type: string
          title: Name of card
          maxLength: 255
        oracleId:
          type: string
          format: uuid
          nullable: true
          title: Scryfall Oracle ID of card
        spoiler:
          type: boolean
          title: Is spoiler
          description: Is this from an upcoming set?
        typeLine:
          type: string
          title: Type line of card
          maxLength: 255
        imageUriFrontPng:
          type: string
          format: uri
          nullable: true
          title: Image URI of the front of the card in PNG format
          maxLength: 200
        imageUriFrontLarge:
          type: string
          format: uri
          nullable: true
          title: Image URI of the front of the card in large format
          maxLength: 200
        imageUriFrontNormal:
          type: string
          format: uri
          nullable: true
          title: Image URI of the front of the card in normal format
          maxLength: 200
        imageUriFrontSmall:
          type: string
          format: uri
          nullable: true
          title: Image URI of the front of the card in small format
          maxLength: 200
        imageUriFrontArtCrop:
          type: string
          format: uri
          nullable: true
          title: Image URI of the card art crop
          maxLength: 200
        layoutRotationFront:
          allOf:
          - $ref: '#/components/schemas/LayoutRotationEnum'
          nullable: true
          title: Layout rotation of the front of the card
        imageUriBackPng:
          type: string
          format: uri
          nullable: true
          title: Image URI of the back of the card in PNG format
          maxLength: 200
        imageUriBackLarge:
          type: string
          format: uri
          nullable: true
          title: Image URI of the back of the card in large format
          maxLength: 200
        imageUriBackNormal:
          type: string
          format: uri
          nullable: true
          title: Image URI of the back of the card in normal format
          maxLength: 200
        imageUriBackSmall:
          type: string
          format: uri
          nullable: true
          title: Image URI of the back of the card in small format
          maxLength: 200
        imageUriBackArtCrop:
          type: string
          format: uri
          nullable: true
          title: Image URI of the back of the card art crop
          maxLength: 200
      required:
      - id
      - imageUriBackArtCrop
      - imageUriBackLarge
      - imageUriBackNormal
      - imageUriBackPng
      - imageUriBackSmall
      - imageUriFrontArtCrop
      - imageUriFrontLarge
      - imageUriFrontNormal
      - imageUriFrontPng
      - imageUriFrontSmall
      - layoutRotationFront
      - name
      - oracleId
      - spoiler
      - typeLine
    CardDetail:
