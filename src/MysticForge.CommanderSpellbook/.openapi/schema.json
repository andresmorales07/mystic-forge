      - imageUriBackArtCrop
      - imageUriBackLarge
      - imageUriBackNormal
      - imageUriBackPng
      - imageUriBackSmall
      - imageUriFrontArtCrop
      - imageUriFrontLarge
      - imageUriFrontNormal
      - imageUriFrontPng
      - imageUriFrontSmall
      - keywords
      - latestPrintingSet
      - layoutRotationFront
