      - cookieAuth: []
      - jwtAuth: []
      responses:
        '204':
          description: No response body
  /variant-suggestions/{id}/validate/:
    put:
      operationId: variant_suggestions_validate_update
      description: Validate the variant suggestion update data.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this variant suggestion.
        required: true
      tags:
      - variant-suggestions
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/VariantSuggestionRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/VariantSuggestionRequest'
          multipart/form-data:
            schema:
              $ref: '#/components/schemas/VariantSuggestionRequest'
        required: true
      security:
      - basicAuth: []
      - cookieAuth: []
      - jwtAuth: []
      responses:
        '200':
          content:
            application/json:
              schema:
                $ref: '#/components/schemas/VariantSuggestion'
          description: ''
    patch:
      operationId: variant_suggestions_validate_partial_update
      description: Validate the variant suggestion update data.
      parameters:
      - in: path
        name: id
        schema:
          type: integer
        description: A unique integer value identifying this variant suggestion.
        required: true
      tags:
      - variant-suggestions
      requestBody:
        content:
          application/json:
            schema:
              $ref: '#/components/schemas/PatchedVariantSuggestionRequest'
          application/x-www-form-urlencoded:
            schema:
              $ref: '#/components/schemas/PatchedVariantSuggestionRequest'
